{
  "compilerOptions": {
    /* Language & Environment */
    "target": "ESNext",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    /* Module System */
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* React */
    "jsx": "react-jsx",

    /* Type Safety & Build */
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,

    /* Path Alias */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* Prevent unwanted global type injections */
    "types": []
  },
  "include": ["src"]
}
